# ============================================================
# Painel Digital — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# === Servidor ===
PORT=3001
NODE_ENV=production

# === Banco de Dados (Railway PostgreSQL) ===
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === JWT ===
# Chave secreta forte — gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=sua_chave_secreta_super_forte_aqui

# === Cloudflare R2 (Armazenamento de Mídia) ===
# Encontre no painel: Cloudflare → R2 → Manage R2 API Tokens
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=sua_access_key_aqui
R2_SECRET_ACCESS_KEY=sua_secret_key_aqui
R2_BUCKET_NAME=nome-do-seu-bucket
# URL pública do bucket (configure em R2 → Settings → Public Access)
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# === CORS / Frontend ===
# URL do frontend no Railway (ou domínio customizado)
FRONTEND_URL=https://seu-projeto.up.railway.app

# === Upload (apenas para desenvolvimento local) ===
# Em produção no Railway, as mídias vão direto para o R2
UPLOAD_DIR=./uploads
